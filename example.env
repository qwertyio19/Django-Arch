# PRODUCTION: True для сервера, False для локальной разработки
PRODUCTION=False

# DEBUG: Режим отладки (включать только при разработке!)
DEBUG=True

# SECRET_KEY: Секретный ключ
SECRET_KEY=django-insecure-CHANGE_ME_SUPER_SECRET_KEY

# ===== Хосты (Домены) =====
# Список разрешенных доменов для работы приложения (для сревера)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Список конкретных URL сайта, которым разрешен доступ к API, (для сервера)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173/,http://127.0.0.1:5173/

# ===== База данных (PostgreSQL) =====
# Данные для подключения к БД (раскомментировать при использовании Postgres), (для сервера)
# POSTGRES_DB=my_db
# POSTGRES_USER=my_user
# POSTGRES_PASSWORD=strong_password_here
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432